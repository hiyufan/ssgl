# Frontend environment configuration (Vite).
# Copy to .env.local and adjust per environment. All vars must be prefixed VITE_.

# Go backend API base URL. In dev the Vite proxy forwards /api -> :8080,
# so the default "/api/v1" works without setting this. In production set it
# to the deployed backend, e.g. https://api.example.com/api/v1
VITE_API_BASE_URL=/api/v1

# Python AI service base URL.
VITE_AI_BASE_URL=http://localhost:8000/ai/api/v1
